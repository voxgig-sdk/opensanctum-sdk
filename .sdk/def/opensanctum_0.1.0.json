{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenSanctum API",
    "description": "OpenSanctum API provides detailed information about various places of worship and religious traditions around the world. It is designed for users interested in exploring sacred sites, spiritual practices, and diverse faiths globally.",
    "version": "1.0.0",
    "contact": {
      "url": "https://www.opensanctum.com"
    }
  },
  "servers": [
    {
      "url": "https://www.opensanctum.com/api",
      "description": "Production server"
    }
  ],
  "paths": {
    "/places": {
      "get": {
        "summary": "Get places of worship",
        "description": "Retrieve a list of places of worship and sacred sites from around the world",
        "operationId": "getPlaces",
        "tags": [
          "Places"
        ],
        "parameters": [
          {
            "name": "country",
            "in": "query",
            "description": "Filter places by country",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "religion",
            "in": "query",
            "description": "Filter places by religion or faith tradition",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "Christianity",
                "Islam",
                "Hinduism",
                "Buddhism",
                "Judaism",
                "Sikhism",
                "Other"
              ]
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Filter places by type of worship site",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "Temple",
                "Church",
                "Mosque",
                "Synagogue",
                "Shrine",
                "Cathedral",
                "Monastery"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results to return",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of results to skip for pagination",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with list of places",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Place"
                      }
                    },
                    "pagination": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer"
                        },
                        "limit": {
                          "type": "integer"
                        },
                        "offset": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/traditions": {
      "get": {
        "summary": "Get religious traditions",
        "description": "Retrieve information about various religious traditions and spiritual practices from around the world",
        "operationId": "getTraditions",
        "tags": [
          "Traditions"
        ],
        "parameters": [
          {
            "name": "religion",
            "in": "query",
            "description": "Filter traditions by religion",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "Christianity",
                "Islam",
                "Hinduism",
                "Buddhism",
                "Judaism",
                "Sikhism",
                "Other"
              ]
            }
          },
          {
            "name": "region",
            "in": "query",
            "description": "Filter traditions by geographical region",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "Asia",
                "Europe",
                "Africa",
                "North America",
                "South America",
                "Oceania",
                "Middle East"
              ]
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Search traditions by name or description",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results to return",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of results to skip for pagination",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with list of traditions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Tradition"
                      }
                    },
                    "pagination": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer"
                        },
                        "limit": {
                          "type": "integer"
                        },
                        "offset": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Place": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the place"
          },
          "name": {
            "type": "string",
            "description": "Name of the place of worship"
          },
          "type": {
            "type": "string",
            "description": "Type of worship site",
            "enum": [
              "Temple",
              "Church",
              "Mosque",
              "Synagogue",
              "Shrine",
              "Cathedral",
              "Monastery"
            ]
          },
          "religion": {
            "type": "string",
            "description": "Primary religion or faith tradition"
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the place"
          },
          "location": {
            "type": "object",
            "properties": {
              "address": {
                "type": "string"
              },
              "city": {
                "type": "string"
              },
              "country": {
                "type": "string"
              },
              "coordinates": {
                "type": "object",
                "properties": {
                  "latitude": {
                    "type": "number",
                    "format": "double"
                  },
                  "longitude": {
                    "type": "number",
                    "format": "double"
                  }
                }
              }
            }
          },
          "yearEstablished": {
            "type": "integer",
            "description": "Year the place was established or built"
          },
          "significance": {
            "type": "string",
            "description": "Historical or spiritual significance"
          },
          "imageUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL to an image of the place"
          },
          "website": {
            "type": "string",
            "format": "uri",
            "description": "Official website URL"
          }
        }
      },
      "Tradition": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the tradition"
          },
          "name": {
            "type": "string",
            "description": "Name of the religious tradition or practice"
          },
          "religion": {
            "type": "string",
            "description": "Associated religion"
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the tradition"
          },
          "origin": {
            "type": "object",
            "properties": {
              "region": {
                "type": "string",
                "description": "Geographical region of origin"
              },
              "country": {
                "type": "string",
                "description": "Country of origin"
              },
              "period": {
                "type": "string",
                "description": "Historical period of origin"
              }
            }
          },
          "practices": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of associated practices or rituals"
          },
          "observances": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "frequency": {
                  "type": "string"
                }
              }
            },
            "description": "Regular observances or ceremonies"
          },
          "culturalSignificance": {
            "type": "string",
            "description": "Cultural and historical significance"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Places",
      "description": "Operations related to places of worship and sacred sites"
    },
    {
      "name": "Traditions",
      "description": "Operations related to religious traditions and spiritual practices"
    }
  ]
}
